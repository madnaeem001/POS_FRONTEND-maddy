<Window x:Class="POS_FRONTEND.settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - POS System"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid>
        <!-- Main Layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="244"/>
            <!-- Sidebar -->
            <ColumnDefinition/>
            <!-- Main Content -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="133*"/>
                <RowDefinition Height="149*"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="10,0,-10,0" Grid.RowSpan="2" RenderTransformOrigin="0.483,0.485">

                <!-- Settings Options -->
                <TextBlock Text="General Settings" 
                           FontSize="18" 
                           FontWeight="SemiBold" 
                           Margin="0,10" />
                <StackPanel Orientation="Vertical" Margin="0,5">
                    <!-- Option 3 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 3: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 4 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 4: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 5 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 5: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 6 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 6: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 7 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 7: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 8 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 8: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 9 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 9: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 10 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 10: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 11 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 11: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 12 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 12: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 13 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 13: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>

                    <!-- Option 14 -->
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Option 14: " FontSize="14" Margin="5,0" />
                        <CheckBox Content="Enable Feature" Margin="10,0" />
                    </StackPanel>
                </StackPanel>


                <!-- Buttons for Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="20,10">
                    <Button Content="Save Settings" 
                            Width="150" 
                            Margin="5" 
                            Background="#27AE60" 
                            Foreground="White" 
                            FontWeight="Bold" />
                    <Button Content="Reset" 
                            Width="100" 
                            Margin="5" 
                            Background="#E74C3C" 
                            Foreground="White" 
                            FontWeight="Bold" />
                </StackPanel>
            </StackPanel>
        </Grid>
        <StackPanel Background="#1F2937" Width="250" HorizontalAlignment="Center">
            <TextBlock Text="POS System" FontSize="24" FontWeight="Bold" Foreground="White" Margin="20" />
            <Button Content="Dashboard" Click="goToDashboard" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Sales" Click="SalesButton_Click" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Items" Click ="Goto_Items" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Reports" Click="Goto_Reports" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Settings" Click ="Goto_Settings" Margin="10" Background="#3F4C67" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Logout" Margin="10" Background="#FF4C4C" Foreground="White" BorderBrush="Transparent" Height="50" Click="LogoutButton_Click" />
        </StackPanel>
    </Grid>
</Window>
