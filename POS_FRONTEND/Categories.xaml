<Window x:Class="POS_FRONTEND.Categories"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Categories" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen" Background="#F8F9FA">
    <Grid Margin="0,38,100,-6">
        <Grid.RowDefinitions>
            <RowDefinition Height="334*" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="345*" />
        </Grid.RowDefinitions>
        <!-- Header Section -->
        <DockPanel Background="White" Height="89" VerticalAlignment="Top" Margin="255,-34,25,0">
            <TextBlock Text="Category" FontSize="30" FontWeight="Bold" Foreground="#1F2937" Margin="20" HorizontalAlignment="Left" />
        </DockPanel>

        <!-- Sidebar Navigation -->
        <StackPanel Background="#1F2937" Width="250" HorizontalAlignment="Left" Grid.RowSpan="3" Margin="0,-34,0,0">
            <TextBlock Text="POS System" FontSize="24" FontWeight="Bold" Foreground="White" Margin="20" />
            <Button Content="Dashboard" Click="goToDashboard" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Sales" Click="SalesButton_Click" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Items" Click="Goto_Items" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Categories" Margin="10" Background="#3F4C67" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Suppliers" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Reports" Click="Goto_Reports" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Settings" Margin="10" Click="Goto_Settings" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Logout" Margin="10" Background="#FF4C4C" Foreground="White" BorderBrush="Transparent" Height="50" Click="LogoutButton_Click"/>
        </StackPanel>

        <!-- Add Category Form -->
        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="290,107,0,0" Height="331" Grid.RowSpan="3">
            <TextBlock Text="Add Category" FontSize="20" FontWeight="Bold" Foreground="#1F2937" Margin="5"/>
            <TextBlock Text="Category ID:" VerticalAlignment="Center" Margin="5"/>
            <TextBox Name="txtC_ID" Width="300" Height="30" Margin="5"/>
            <TextBlock Text="Category Name:" VerticalAlignment="Center" Margin="5"/>
            <TextBox Name="txtC_Name" Width="300" Height="30" Margin="5"/>
            <TextBlock Text="Description:" VerticalAlignment="Center" Margin="5"/>
            <TextBox Name="txtDescription" Width="300" Height="30" Margin="5"/>
        </StackPanel>

        <!-- Buttons Section -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="290,26,0,0" Grid.Row="2" Width="360" VerticalAlignment="Top">
            <Button Content="Add Category" Width="120" Height="30" Background="#3498DB" Foreground="White"/>
        </StackPanel>

        <DataGrid Name="CategoriesDataGrid" Margin="748,94,-80,276" AutoGenerateColumns="False" HeadersVisibility="Column" CanUserSortColumns="True" SelectionMode="Single" IsReadOnly="True" SelectionChanged="SalesDataGrid_SelectionChanged" Grid.RowSpan="3" Panel.ZIndex="-1">
            <DataGrid.Columns>
                <!-- Add the necessary columns based on the fields you want to display -->
                <DataGridTextColumn Header="Customer Name" Binding="{Binding CustomerName}" Width="150" />
                <DataGridTextColumn Header="Item Name" Binding="{Binding ItemName}" Width="150" />
                <DataGridTextColumn Header="Stock Code" Binding="{Binding StockCode}" Width="120" />

            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="905,121,0,0" Grid.Row="2" Width="360" VerticalAlignment="Top">
            <Button Content="Remove Item" Width="120" Height="30" Background="#3498DB" Foreground="White" Click="Button_Click" Margin="0,0,10,0" />
            <Button Content="Edit Item" Width="120" Height="30" Background="#3498DB" Foreground="White" Click="openEditItems" />
        </StackPanel>
        <Button Content="Add Item" Width="120" Height="30" Background="#3498DB" Foreground="White" Click="openAddItems" Margin="614,276,811,30" Grid.Row="2"/>


    </Grid>
</Window>
