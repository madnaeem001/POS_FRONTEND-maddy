<Window x:Class="POS_FRONTEND.Sales"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sales" Height="700" Width="1200" Background="#F4F4F9">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="334*" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="345*" />
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <DockPanel Background="White" Height="80" VerticalAlignment="Top" Margin="255,4,0,0">
            <TextBlock FontSize="30" FontWeight="Bold" Foreground="#1F2937" Margin="20" HorizontalAlignment="Left" ><Run Foreground="#FF2C3E50" FontSize="28" Text="Sales"/></TextBlock>
        </DockPanel>

        <!-- Sidebar Navigation -->
        <StackPanel Background="#1F2937" Width="250" HorizontalAlignment="Left" Grid.RowSpan="3">
            <TextBlock Text="POS System" FontSize="24" FontWeight="Bold" Foreground="White" Margin="20" />
            <Button Content="Dashboard" Click="goToDashboard" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Sales" Margin="10" Background="#3F4C67" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Items" Click ="Goto_Items" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Categories" Margin="10"   Click="Goto_Cat" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Suppliers" Margin="10"   Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Reports" Click="Goto_Reports" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Settings" Click="Goto_Settings" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Logout" Margin="10" Background="#FF4C4C" Foreground="White" BorderBrush="Transparent" Height="50" Click="LogoutButton_Click" />
        </StackPanel>

        <!-- Title and Filter Section -->
        <StackPanel Orientation="Vertical" Margin="255,115,10,0" Grid.RowSpan="3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10" Width="485">
                <TextBlock Text="Range:" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                <DatePicker x:Name="StartDatePicker" Width="120" Height="30" />
                <TextBlock Text=" - " FontSize="16" VerticalAlignment="Center" />
                <DatePicker x:Name="EndDatePicker" Width="120" Height="30" />
                <Button Content="Search" Background="#3498DB" Foreground="White" Margin="20,0,0,0" Width="150" Height="30" Click="SearchButton_Click" />
            </StackPanel>
        </StackPanel>

        <!-- DataGrid Section -->
        <DataGrid Name="SalesDataGrid" Margin="272,199,28,65" AutoGenerateColumns="False" HeadersVisibility="Column" CanUserSortColumns="True" SelectionMode="Single" IsReadOnly="True" Grid.RowSpan="3">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time of Order" Binding="{Binding TimeOfOrder}" Width="150" />
                <DataGridTextColumn Header="Invoice ID" Binding="{Binding TransactionID}" Width="200" />
                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="100" />
                <DataGridTextColumn Header="Quantity Sold" Binding="{Binding QuantitySold}" Width="100" />
                <DataGridTextColumn Header="Unit Price" Binding="{Binding Price}" Width="100" />
                <DataGridTextColumn Header="Total Price" Binding="{Binding TotalSales}" Width="150" />
                <DataGridTextColumn Header="Transaction Total" Binding="{Binding TransactionTotal}" Width="100" />
                <DataGridTextColumn Header="Paid Amount" Binding="{Binding PaidAmount}" Width="100" />
                <DataGridTextColumn Header="Change" Binding="{Binding Change}" Width="100" />
                <DataGridTextColumn Header="Handled By" Binding="{Binding HandledBy}" Width="100" />
                <DataGridTextColumn Header="Profit" Binding="{Binding Profit}" Width="100" />
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Export and Print Buttons -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,10,10" HorizontalAlignment="Right" Grid.Row="2">
            <Button Content="Export CSV" Click="ExportCsvButton_Click" Width="120" Height="30" Background="#2ECC71" Foreground="White" Margin="10,0,0,0" />
            <Button Content="Print" Width="120" Height="30" Background="#3498DB" Foreground="White" Margin="10,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
