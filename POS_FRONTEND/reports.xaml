<Window x:Class="POS_FRONTEND.reports"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reports - POS System"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid>
        <!-- Main Layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Main Content -->
        </Grid.ColumnDefinitions>
        
        <DockPanel Background="White" Height="80" VerticalAlignment="Top" Margin="262,4,18,0">
            <TextBlock Text="Items" FontSize="30" FontWeight="Bold" Foreground="#1F2937" Margin="20" HorizontalAlignment="Left" />
        </DockPanel>

        <!-- Sidebar -->
        <!-- Sidebar Navigation -->

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="55,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="78*"/>
                <RowDefinition Height="9*"/>
                <RowDefinition Height="7*"/>
            </Grid.RowDefinitions>
            <StackPanel HorizontalAlignment="Center" Width="736" Grid.RowSpan="3" Margin="0,51,0,-51">

                <!-- Reports Table -->
                <DataGrid Name="ReportsDataGrid" 
                          AutoGenerateColumns="True" 
                          Margin="0,10" 
                          Height="398" 
                          Background="LightGray" Width="750" />

                <!-- Export and Filter Buttons -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            Margin="0,20">
                    <Button Content="Generate Report" 
                            Width="150" 
                            Margin="5" 
                            Background="#3498DB" 
                            Foreground="White" 
                            FontWeight="Bold" Height="46" />
                    <Button Content="Export to Excel" 
                            Width="150" 
                            Margin="5" 
                            Background="#27AE60" 
                            Foreground="White" 
                            FontWeight="Bold" />
                    <Button Content="Filter Data" 
                            Width="150" 
                            Margin="5" 
                            Background="#F39C12" 
                            Foreground="White" 
                            FontWeight="Bold" />
                </StackPanel>
            </StackPanel>
        </Grid>
        <StackPanel Background="#1F2937" Width="250" HorizontalAlignment="Left" Grid.ColumnSpan="2">
            <TextBlock Text="POS System" FontSize="24" FontWeight="Bold" Foreground="White" Margin="20" />
            <Button Content="Dashboard" Click="goToDashboard" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Sales" Click="SalesButton_Click" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Items" Click="Goto_Items" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Reports" Click="Goto_Reports"  Margin="10" Background="#3F4C67" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Settings" Click="Goto_Settings" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Logout" Margin="10" Background="#FF4C4C" Foreground="White" BorderBrush="Transparent" Height="50" Click="LogoutButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
