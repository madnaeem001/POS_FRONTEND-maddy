<Window x:Class="POS_FRONTEND.MyDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Dashboard"
        Height="768" Width="1366"
        Background="#F7F9FC"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <Grid>
        <!-- Sidebar Navigation -->
        <StackPanel Background="#1F2937" Width="250" VerticalAlignment="Stretch" HorizontalAlignment="Left">
            <TextBlock Text="POS System" FontSize="24" FontWeight="Bold" Foreground="White" Margin="20" />
            <Button Content="Dashboard" Margin="10" Background="#3F4C67" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Sales" Click="SalesButton_Click" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Items" Click="Goto_Items" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Categories" Margin="10"   Click="Goto_Cat" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Suppliers" Margin="10"   Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Reports" Click="Goto_Reports" Margin="10" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Settings" Margin="10"  Click="Goto_Settings" Background="#1F2937" Foreground="White" BorderBrush="Transparent" Height="50" />
            <Button Content="Logout" Margin="10" Background="#FF4C4C" Foreground="White" BorderBrush="Transparent" Height="50" Click="LogoutButton_Click"/>
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Margin="250,0,0,0">
            <Grid.RowDefinitions>
                <!-- Upper section for metrics -->
                <RowDefinition Height="Auto" />
                <!-- Lower section for graph -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <DockPanel Background="White" Height="80" VerticalAlignment="Top" Margin="0,0,0,10">
                <TextBlock Text="Dashboard" FontSize="30" FontWeight="Bold" Foreground="#1F2937" Margin="20" />
                <TextBlock Text="Welcome, Sheikh" FontSize="16" Foreground="#6B7280" Margin="0,0,20,0" DockPanel.Dock="Right" VerticalAlignment="Center" />
            </DockPanel>

            <!-- Dashboard Content -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <!-- Row for metrics -->
                    <RowDefinition Height="Auto" />
                    <!-- Row for the chart -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Metrics Cards -->
                <UniformGrid Rows="1" Columns="4" Margin="0,0,0,20">
                    <!-- Total Stock Price Value Card -->
                    <Border Background="White" CornerRadius="10" Margin="10" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Total Stock Value" FontWeight="Bold" FontSize="18" Foreground="#4CAF50" />
                            <TextBlock x:Name="TotalStockValueTextBlock" FontSize="28" FontWeight="Bold" Foreground="#1F2937" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Total Sales Card -->
                    <Border Background="White" CornerRadius="10" Margin="10" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Total Sales" FontWeight="Bold" FontSize="18" Foreground="#FF9800" />
                            <TextBlock x:Name="TotalSalesTextBlock" FontSize="28" FontWeight="Bold" Foreground="#1F2937" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Profit Card -->
                    <Border Background="White" CornerRadius="10" Margin="10" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Profit" FontWeight="Bold" FontSize="18" Foreground="#2196F3" />
                            <TextBlock x:Name="ProfitTextBlock" FontSize="28" FontWeight="Bold" Foreground="#1F2937" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Stock Card -->
                    <Border Background="White" CornerRadius="10" Margin="10" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Stock" FontWeight="Bold" FontSize="18" Foreground="#FFC107" />
                            <TextBlock x:Name="TotalStockQuantityTextBlock" FontSize="28" FontWeight="Bold" Foreground="#1F2937" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Daily Sales Graph -->
                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <TextBlock Text="Daily Sales" FontSize="22" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,10" HorizontalAlignment="Left"/>
                    <lvc:CartesianChart Name="SalesChart" Margin="0,56,0,0" >
                        <lvc:CartesianChart.Series>
                            <lvc:ColumnSeries Title="Daily Sales" Values="{Binding SalesData}" />
                        </lvc:CartesianChart.Series>
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Date" 
                                      Labels="{Binding SalesDates}" 
                                      LabelFormatter="{Binding DateFormatter}" />
                        </lvc:CartesianChart.AxisX>
                    </lvc:CartesianChart>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
