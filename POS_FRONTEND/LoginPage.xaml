<Window x:Class="POS_FRONTEND.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login Page" Height="768" Width="1366" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!-- Background Gradient for Window -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E6F7FF" Offset="0"/>
                <GradientStop Color="#D0E8F2" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Main Form Container -->
        <Border Background="White" Padding="40" BorderBrush="#E6E6E6" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Title -->
                <TextBlock Text="Al-Sheikh SuperMart" FontSize="25" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,30" />

                <!-- Username Field -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="User Name" VerticalAlignment="Center" Width="100" Foreground="#333333" FontWeight="SemiBold"/>
                    <TextBox x:Name="UsernameTextBox" Width="158" Height="27" Margin="10,0" Padding="5" BorderBrush="#B0B0B0" BorderThickness="1" FontSize="14"/>
                </StackPanel>

                <!-- Password Field -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                    <TextBlock Text="Password" VerticalAlignment="Center" Width="100" Foreground="#333333" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="PasswordBox" Width="158" Height="27" Margin="10,0" Padding="5" BorderBrush="#B0B0B0" BorderThickness="1" FontSize="14"/>
                </StackPanel>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessage" Foreground="Red" FontSize="14" HorizontalAlignment="Center" Margin="0,10" Visibility="Collapsed"/>

                <!-- Login Button -->
                <Button x:Name="LoginButton" Content="Login" Click="LoginButton_Click" Height="45" Background="#0078D4" Foreground="White" BorderBrush="#0078D4" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Cursor="Hand" Padding="10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Padding="10,0" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
